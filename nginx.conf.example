server {
    listen 80;
    server_name trafy.tr www.trafy.tr;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name trafy.tr www.trafy.tr;

    # SSL sertifikalari -- kendi yollariniza gore guncelleyin
    ssl_certificate /etc/ssl/certs/trafy.tr.crt;
    ssl_certificate_key /etc/ssl/private/trafy.tr.key;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # Guvenlik header'lari
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # Proxy to Node.js
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Statik dosya cache
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|mp4|woff2)$ {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        expires 7d;
        add_header Cache-Control "public, immutable";
    }
}
