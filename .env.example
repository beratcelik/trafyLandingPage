# Param Sanal POS
PARAM_CLIENT_CODE=
PARAM_CLIENT_USERNAME=
PARAM_CLIENT_PASSWORD=
PARAM_CLIENT_GUID=

# Admin paneli
ADMIN_SECRET=

# Genel
DOMAIN=https://trafy.tr
PORT=3000

# Trendyol eFaturam - E-Arşiv Fatura
# MOCK=true iken gerçek credential olmadan test edilebilir.
# Canlı gateway: https://apigateway.trendyolecozum.com
INVOICE_MOCK=true
TRENDYOL_INVOICE_BASE_URL=https://stage-apigateway.trendyolefaturam.com
TRENDYOL_PARTNER_USERNAME=
TRENDYOL_PARTNER_PASSWORD=
TRENDYOL_CUSTOMER_USERNAME=
TRENDYOL_CUSTOMER_PASSWORD=
TRENDYOL_SUPPLIER_ID=

# Fatura üzerinde görünecek firma bilgileri
COMPANY_NAME=
COMPANY_TAX_NUMBER=
COMPANY_TAX_OFFICE=

# Android APK release manager
# Manifest signing private key (server tarafindan korunur, repo disinda)
# Ilk kez calistirma: node scripts/generate-apk-signing-key.js
APK_SIGN_KEY_PATH=/etc/trafy/apk_sign_private.pem
# Ayni anahtarin public kismi (Android uygulamasinda gomulu olan ile esit olmali)
APK_SIGN_PUBLIC_B64=
# Yukleme limiti (MB, varsayilan 100)
APK_MAX_MB=100
# apksigner CLI yolu (Ubuntu: sudo apt install android-sdk-build-tools)
APKSIGNER_PATH=apksigner
# Release keystore sertifika fingerprint'i (apksigner verify --print-certs ciktisindan)
# Bos birakilirsa ilk yuklemede otomatik pinlenir.
APK_RELEASE_CERT_SHA256=
